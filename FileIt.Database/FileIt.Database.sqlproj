<?xml version="1.0" encoding="utf-8"?>
<Project DefaultTargets="Build">
  <Sdk Name="Microsoft.Build.Sql" Version="2.0.0" />
  <PropertyGroup>
    <Name>FileIt.Database</Name>
    <ProjectGuid>{430BB322-A989-4F38-8C3A-EAEFCAF75448}</ProjectGuid>
    <DSP>Microsoft.Data.Tools.Schema.Sql.SqlAzureV12DatabaseSchemaProvider</DSP>
    <ModelCollation>1033, CI</ModelCollation>
  </PropertyGroup>
  <ItemGroup>
    <None Include=".vscode\tasks.json" />
    <None Include="fileit_azure.publish.xml" />
    <None Include="fileit_local.publish.xml" />
  </ItemGroup>
  <ItemGroup>
    <Folder Include="Tables" />
  </ItemGroup>
  <ItemGroup>
    <Build Remove="fileit.sql" />
    <Build Remove="Scripts\**\*.sql" />
    <None Include="Scripts\**\*.sql" />
  </ItemGroup>
  <Target Name="BeforeBuild">
    <Delete Files="$(BaseIntermediateOutputPath)\project.assets.json" />
  </Target>
</Project>