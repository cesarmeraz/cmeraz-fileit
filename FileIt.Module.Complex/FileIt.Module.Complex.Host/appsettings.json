{
  "Feature": {
    "BaseUrl": "http://localhost:7064",
    "MaxPageSize": 100,
    "Latency": {
      "Enabled": true,
      "MinMs": 50,
      "MaxMs": 300
    },
    "Chaos": {
      "Enabled": true,
      "Failure503Rate": 0.05,
      "RetryAfterSeconds": 2,
      "ExemptPaths": [ "/api/health", "/api/docs" ]
    },
    "Idempotency": {
      "Enabled": true,
      "HeaderName": "Idempotency-Key",
      "MaxKeyLength": 128
    }
  },
  "ConnectionStrings": {
    "FileIt": ""
  },
  "Logging": {
    "Default": "Information",
    "Microsoft.Azure.Functions.Worker": "Warning",
    "FileIt": "Debug"
  }
}
