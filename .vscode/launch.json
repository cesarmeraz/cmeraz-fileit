{
    // Use IntelliSense to learn about possible attributes.
    // Hover to view descriptions of existing attributes.
    // For more information, visit: https://go.microsoft.com/fwlink/?linkid=830387
    "version": "0.2.0",
    "configurations": [
        {
            "name": "SqlPackage: Local",
            "type": "node-terminal",
            "request": "launch",
            "preLaunchTask": "publish-db-local",
            "command": "echo publish-db-local completed"
        },
        {
            "name": "SqlPackage: Azure",
            "type": "node-terminal",
            "request": "launch",
            "preLaunchTask": "publish-db-azure",
            "command": "echo publish-db-azure completed"
        },
        {
            "name": "Start AppHost",
            "type": "dotnet",
            "request": "launch",
            "projectPath": "${workspaceFolder}/FileIt.AppHost/FileIt.AppHost.csproj",
            "env": {
                "ASPNETCORE_ENVIRONMENT": "Development",
                "DOTNET_ENVIRONMENT": "Development"
            }
        },
        {
            "name": "Start Services",
            "type": "coreclr",
            "request": "attach",
            "preLaunchTask": "start services",
            "processId": "${command:azureFunctions.pickProcess}"
        },
        {
            "name": "Start Simple Flow",
            "type": "coreclr",
            "request": "attach",
            "preLaunchTask": "start simple",
            "processId": "${command:azureFunctions.pickProcess}"
        },
        {
            "type": "bashdb",
            "request": "launch",
            "name": "Bash",
            "cwd": "${workspaceFolder}",
            "program": "${file}",
            "terminalKind": "integrated"
        }
    ]
}