{
    // Use IntelliSense to learn about possible attributes.
    // Hover to view descriptions of existing attributes.
    // For more information, visit: https://go.microsoft.com/fwlink/?linkid=830387
    "version": "0.2.0",
    "configurations": [
        {
            "name": "Start Services",
            "type": "coreclr",
            "request": "attach",
            "preLaunchTask": "start services",
            "processId": "${command:azureFunctions.pickProcess}"
        },
        {
            "name": "Start Simple Flow",
            "type": "coreclr",
            "request": "attach",
            "preLaunchTask": "start simple",
            "processId": "${command:azureFunctions.pickProcess}"
        },
        {
            "name": "Publish Services",
            "type": "bashdb",
            "request": "launch",
            "preLaunchTask": "validate telemetry packages",
            "program": "${workspaceFolder}/scripts/publish/publish-services.sh",
            "terminalKind": "integrated"
        },
        {
            "name": "Publish Simple Flow",
            "type": "bashdb",
            "request": "launch",
            "preLaunchTask": "validate telemetry packages",
            "program": "${workspaceFolder}/scripts/publish/publish-simple.sh",
            "terminalKind": "integrated"
        },
        {
            "type": "bashdb",
            "request": "launch",
            "name": "Bash",
            "cwd": "${workspaceFolder}",
            "program": "${file}",
            "terminalKind": "integrated"
        }
    ]
}